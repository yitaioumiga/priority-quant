{
  "skill_name": "priority-quant",
  "version": "1.1.0",
  "description": "项目优先级量化评估 - 多智能体适配版",
  "compatibility": {
    "programming_agents": {
      "claude_code": {
        "compatible": true,
        "trigger_patterns": ["/project-priority", "项目优先级", "优先级评估", "项目排序"],
        "execution_mode": "direct",
        "script_runner": "python",
        "working_dir": "${SKILL_DIR}"
      },
      "codex": {
        "compatible": true,
        "trigger_patterns": ["evaluate project priority", "project ranking"],
        "execution_mode": "sandbox",
        "script_runner": "python",
        "sandbox_config": {
          "timeout": 30,
          "memory_limit": "512MB"
        }
      },
      "windsurf": {
        "compatible": true,
        "trigger_patterns": ["项目评估", "priority评估"],
        "execution_mode": "workspace",
        "script_runner": "python",
        "workspace_config": {
          "auto_save": true,
          "sync_state": true
        }
      },
      "cursor": {
        "compatible": true,
        "trigger_patterns": ["evaluate priority", "rank projects"],
        "execution_mode": "inline",
        "script_runner": "python",
        "inline_config": {
          "show_preview": true,
          "auto_format": true
        }
      },
      "trae": {
        "compatible": true,
        "trigger_patterns": ["项目优先级", "评估项目"],
        "execution_mode": "integrated",
        "script_runner": "python"
      },
      "github_copilot": {
        "compatible": true,
        "trigger_patterns": ["project priority", "priority evaluation"],
        "execution_mode": "chat",
        "script_runner": "python",
        "chat_config": {
          "suggestion_mode": "inline",
          "context_window": 10
        }
      }
    },
    "autonomous_agents": {
      "openclaw": {
        "compatible": true,
        "trigger_patterns": ["项目优先级", "优先级评估", "项目排序", "任务管理"],
        "execution_mode": "autonomous",
        "task_planning": {
          "enabled": true,
          "decomposition_depth": 3,
          "dependency_tracking": true
        },
        "autonomous_features": {
          "scheduled_execution": true,
          "proactive_monitoring": true,
          "decision_making": true,
          "multi_step_workflows": true
        },
        "task_templates": {
          "weekly_review": {
            "description": "周度项目优先级复盘",
            "steps": [
              "收集本周新增项目",
              "评估各项目优先级分数",
              "生成优先级排序报告",
              "提醒高优先级项目待处理"
            ],
            "schedule": "每周一上午"
          },
          "monthly_report": {
            "description": "月度项目优先级报告",
            "steps": [
              "汇总本月所有项目",
              "分析优先级变化趋势",
              "评估项目完成情况",
              "生成月度优先级报告",
              "提供资源分配建议"
            ],
            "schedule": "每月1-3日"
          },
          "project_intake": {
            "description": "新项目入库评估",
            "steps": [
              "接收新项目描述",
              "执行6维度评分",
              "检查战略对齐度",
              "生成评估报告",
              "更新项目优先级列表"
            ],
            "trigger": "新项目提交"
          }
        }
      },
      "hermes": {
        "compatible": true,
        "trigger_patterns": ["项目优先级", "优先级评估", "项目排序", "任务管理"],
        "execution_mode": "autonomous",
        "task_planning": {
          "enabled": true,
          "decomposition_depth": 4,
          "dependency_tracking": true,
          "parallel_execution": true
        },
        "autonomous_features": {
          "scheduled_execution": true,
          "proactive_monitoring": true,
          "decision_making": true,
          "multi_step_workflows": true,
          "context_awareness": true,
          "learning_from_history": true
        },
        "task_templates": {
          "weekly_review": {
            "description": "周度项目优先级复盘",
            "steps": [
              "收集本周新增项目",
              "执行批量优先级评估",
              "分析优先级变化趋势",
              "生成可视化报告",
              "推送高优先级提醒"
            ],
            "schedule": "每周一上午",
            "priority": "high"
          },
          "monthly_report": {
            "description": "月度项目优先级报告",
            "steps": [
              "汇总本月所有项目",
              "深度分析优先级变化",
              "评估资源分配效率",
              "识别瓶颈和风险",
              "生成月度报告",
              "提供优化建议"
            ],
            "schedule": "每月1-3日",
            "priority": "high"
          },
          "project_intake": {
            "description": "新项目入库评估",
            "steps": [
              "接收新项目描述",
              "AI预审推荐分数",
              "执行6维度精算",
              "检查战略对齐度",
              "生成评估报告",
              "更新项目列表",
              "通知相关人员"
            ],
            "trigger": "新项目提交",
            "priority": "medium"
          },
          "strategic_alignment": {
            "description": "战略对齐度检查",
            "steps": [
              "获取用户当前核心目标",
              "分析所有项目对齐度",
              "识别偏离项目",
              "生成对齐度报告",
              "提供调整建议"
            ],
            "schedule": "每月15日",
            "priority": "medium"
          }
        }
      }
    }
  },
  "execution_modes": {
    "direct": {
      "description": "直接在当前环境执行脚本",
      "pros": ["实时反馈", "无需额外配置"],
      "cons": ["依赖本地Python环境"]
    },
    "sandbox": {
      "description": "在隔离沙箱中执行",
      "pros": ["安全隔离", "资源可控"],
      "cons": ["需要沙箱支持"]
    },
    "workspace": {
      "description": "在工作区环境中执行",
      "pros": ["状态持久化", "支持协作"],
      "cons": ["需要工作区配置"]
    },
    "inline": {
      "description": "内联执行并显示结果",
      "pros": ["即时预览", "无缝集成"],
      "cons": ["可能影响编辑体验"]
    },
    "integrated": {
      "description": "集成到IDE功能中",
      "pros": ["深度集成", "原生体验"],
      "cons": ["需要IDE支持"]
    },
    "chat": {
      "description": "通过对话交互执行",
      "pros": ["自然语言交互", "灵活"],
      "cons": ["可能不够精确"]
    },
    "autonomous": {
      "description": "自主执行模式，支持任务规划和自动执行",
      "pros": ["自动化程度高", "支持复杂工作流", "可定时执行"],
      "cons": ["需要任务规划能力", "可能需要用户确认关键决策"]
    }
  }
}
